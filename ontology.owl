    <!-- http://www.uoc.edu/ontologies/meddevice-eu#BfArM -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/meddevice-eu#BfArM">
        <rdf:type rdf:resource="http://www.uoc.edu/ontologies/meddevice-eu#CompetentAuthority"/>
        <rdfs:comment xml:lang="en">German national competent authority for medical devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Bundesinstitut fuer Arzneimittel und Medizinprodukte (BfArM)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/ontologies/meddevice-eu#ClassC -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/meddevice-eu#ClassC">
        <rdf:type rdf:resource="http://www.uoc.edu/ontologies/meddevice-eu#RiskClass"/>
        <rdfs:comment xml:lang="en">High risk class under IVDR.</rdfs:comment>
        <rdfs:label xml:lang="en">Class C</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/ontologies/meddevice-eu#ClassD -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/meddevice-eu#ClassD">
        <rdf:type rdf:resource="http://www.uoc.edu/ontologies/meddevice-eu#RiskClass"/>
        <rdfs:comment xml:lang="en">Highest risk class under IVDR.</rdfs:comment>
        <rdfs:label xml:lang="en">Class D</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/ontologies/meddevice-eu#ClassIII -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/meddevice-eu#ClassIII">
        <rdf:type rdf:resource="http://www.uoc.edu/ontologies/meddevice-eu#RiskClass"/>
        <rdfs:comment xml:lang="en">Highest risk class under MDR for medical devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Class III</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/ontologies/meddevice-eu#ClassIIa -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/meddevice-eu#ClassIIa">
        <rdf:type rdf:resource="http://www.uoc.edu/ontologies/meddevice-eu#RiskClass"/>
        <rdfs:comment xml:lang="en">Medium-low risk class under MDR.</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIa</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/ontologies/meddevice-eu#ClassIIb -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/meddevice-eu#ClassIIb">
        <rdf:type rdf:resource="http://www.uoc.edu/ontologies/meddevice-eu#RiskClass"/>
        <rdfs:comment xml:lang="en">Medium-high risk class under MDR.</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIb</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/ontologies/meddevice-eu#DEV-001 -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/meddevice-eu#DEV-001">
        <rdf:type rdf:resource="http://www.uoc.edu/ontologies/meddevice-eu#ImplantableActiveDevice"/>
        <hasManufacturer rdf:resource="http://www.uoc.edu/ontologies/meddevice-eu#MAN-001"/>
        <hasRiskClass rdf:resource="http://www.uoc.edu/ontologies/meddevice-eu#ClassIII"/>
        <deviceName>HeartMate 3 LVAD</deviceName>
        <intendedPurpose>Ventricular assist device for end-stage heart failure</intendedPurpose>
        <isActive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isActive>
        <isImplantable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isImplantable>
        <isIvd rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isIvd>
        <isReusable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isReusable>
        <udiDi>(01)00380740009095</udiDi>
        <rdfs:comment xml:lang="en">Ventricular assist device for end-stage heart failure, manufactured by Medtronic.</rdfs:comment>
        <rdfs:label xml:lang="en">HeartMate 3 LVAD</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/ontologies/meddevice-eu#DEV-002 -->


    <owl:NamedIndividual rdf:about="http://www.uoc.edu/ontologies/meddevice-eu#DEV-002">
        <rdf:type rdf:resource="http://www.uoc.edu/ontologies/meddevice-eu#ActiveImplant"/>
        <hasManufacturer rdf:resource="http://www.uoc.edu/ontologies/meddevice-eu#MAN-001"/>
        <hasRiskClass rdf:resource="http://www.uoc.edu/ontologies/meddevice-eu#ClassIII"/>
        <deviceName>Micra AV Transcatheter Pacing System</deviceName>
        <intendedPurpose>Leadless cardiac pacemaker for atrioventricular synchrony</intendedPurpose>
        <isActive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isActive>
        <isImplantable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isImplantable>
        <isIvd rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isIvd>
